<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sist.mapper.team-mapper">
	<resultMap type="TeamVO" id="TeamMap" autoMapping="true">
		<association property="svo" javaType="StadiumVO">
            <result property="capacity" column="capacity"/>
            <result property="name" column="stadium_name"/>
            <result property="longitude" column="longitude"/>
            <result property="latitude" column="latitude"/>
            <result property="address" column="address"/>
        </association>
	</resultMap>
	<select id="teamEmblemData" resultType="TeamVO">
		SELECT team_id,team_name,emblem
		FROM KLeague_team
	</select>
	<select id="teamDetailData" resultMap="TeamMap" parameterType="string">
		SELECT team_id,team_name,t.stadium_id,emblem,s.stadium_name,s.address,s.capacity,s.latitude,s.longitude
		FROM KLeague_Team t JOIN KLeague_Stadium s
		ON t.stadium_id=s.stadium_id
		WHERE team_id=#{team_id}
	</select>
</mapper>